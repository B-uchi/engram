DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DashScope region endpoint. Keys are region-bound!
# International (Singapore) account:  https://dashscope-intl.aliyuncs.com/api/v1
# China (Beijing) account:           https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# Active agent — fast, non-thinking
ACTIVE_MODEL=qwen3-32b
ACTIVE_THINKING=false

# Consolidator — deep reasoning, thinking mode
CONSOLIDATOR_MODEL=qwen3-32b
CONSOLIDATOR_THINKING=true

# Memory store paths
DB_PATH=./engram.db
CHROMA_PATH=./chroma_store
SKILLS_PATH=./skills

# Consolidation schedule (cron expression — default: every 30 minutes)
CONSOLIDATION_CRON=*/30 * * * *

# Decay thresholds
DECAY_ARCHIVE_THRESHOLD=0.15
DECAY_DEPRECATE_THRESHOLD=0.06

# Context window budget (tokens)
CONTEXT_BUDGET_TOKENS=4000

# CORS (for local dev)
ALLOWED_ORIGINS=http://localhost:3000
